@page "/connection-settings"
@using QuickBooksClone.Maui.Services
@using QuickBooksClone.Maui.Services.Settings
@inject ApiConnectionSettingsStore ConnectionStore
@inject ApiConnectivityService Connectivity
@inject LocalApiProcessService LocalApiProcess
@inject AppStartupCoordinator Startup

<PageTitle>Connection Settings</PageTitle>

<div class="qb-page">
    <section class="qb-header">
        <div>
            <div class="eyebrow">Startup</div>
            <h1>Advanced Connection Settings</h1>
            <p class="muted">Local mode starts automatically with the desktop app. LAN and hosted URLs stay here for central sync or multi-device deployment later.</p>
        </div>
        <div class="toolbar">
            <button class="secondary-button" @onclick="Reload">Reset</button>
            <button class="primary-button" @onclick="Save">Save Profiles</button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="panel status-panel @(statusIsError ? "status-error" : "status-success")">
            @statusMessage
        </div>
    }

    <div class="qb-grid">
        <section class="panel">
            <div class="toolbar">
                <strong>Profiles</strong>
            </div>

            <div class="form-stack">
                <label class="form-label">
                    <span>Startup mode</span>
                    <select class="form-control" @bind="model.StartupMode">
                        <option value="@ApiStartupMode.ManagedLocalApi">Automatic Local Startup</option>
                        <option value="@ApiStartupMode.ConnectOnly">Manual External API</option>
                    </select>
                </label>

                <label class="form-label">
                    <span>Startup profile</span>
                    <select class="form-control" @bind="model.StartupProfile">
                        <option value="@ApiConnectionMode.Local">Local</option>
                        <option value="@ApiConnectionMode.Lan">LAN</option>
                        <option value="@ApiConnectionMode.Hosted">Hosted</option>
                    </select>
                </label>

                <label class="form-label">
                    <span>Local API URL</span>
                    <input class="form-control" @bind="model.LocalUrl" />
                </label>

                <label class="form-label">
                    <span>LAN API URL</span>
                    <input class="form-control" @bind="model.LanUrl" />
                </label>

                <label class="form-label">
                    <span>Hosted API URL</span>
                    <input class="form-control" @bind="model.HostedUrl" />
                </label>

                <div class="muted">
                    Use the hosted URL later for central sync or central-office deployment. Daily local startup still runs from the local API and SQLite.
                </div>

                <label class="form-label">
                    <span>Local API project path (optional)</span>
                    <input class="form-control" @bind="model.LocalApiProjectPath" />
                </label>
            </div>
        </section>

        <section class="panel">
            <div class="toolbar">
                <strong>Runtime</strong>
                <button class="secondary-button" @onclick="TestConnection" disabled="@isTesting">@(isTesting ? "Testing..." : "Test Current Connection")</button>
                <button class="secondary-button" @onclick="StartManagedLocalApi" disabled="@isTesting">Start Local API</button>
                <button class="secondary-button" @onclick="StopManagedLocalApi" disabled="@isTesting">Stop Local API</button>
            </div>

            <dl class="summary-list">
                <div>
                    <dt>Active URL</dt>
                    <dd>@activeUrl</dd>
                </div>
                <div>
                    <dt>Environment</dt>
                    <dd>@(runtime?.EnvironmentName ?? "Unknown")</dd>
                </div>
                <div>
                    <dt>Database Provider</dt>
                    <dd>@(runtime?.DatabaseProvider ?? "Unknown")</dd>
                </div>
                <div>
                    <dt>Backup Support</dt>
                    <dd>@(runtime is null ? "Unknown" : runtime.SupportsBackupRestore ? "Enabled" : "Disabled")</dd>
                </div>
                <div>
                    <dt>Backup Directory</dt>
                    <dd>@(runtime?.BackupDirectory ?? "Unknown")</dd>
                </div>
                <div>
                    <dt>Managed Local API</dt>
                    <dd>@(LocalApiProcess.IsRunning ? "Running" : "Not running")</dd>
                </div>
                <div>
                    <dt>Resolved Project Path</dt>
                    <dd>@(lastHealth?.LocalApiProjectPath ?? LocalApiProcess.ResolvedProjectPath ?? "Auto-detect")</dd>
                </div>
            </dl>
        </section>
    </div>
</div>

@code {
    private ApiConnectionSettings model = new();
    private RuntimeSettingsDto? runtime;
    private ConnectionHealthResult? lastHealth;
    private string activeUrl = string.Empty;
    private string? statusMessage;
    private bool statusIsError;
    private bool isTesting;

    protected override void OnInitialized()
    {
        Reload();
    }

    private void Reload()
    {
        model = ConnectionStore.Current;
        activeUrl = ConnectionStore.CurrentBaseUrl;
        statusMessage = null;
        statusIsError = false;
    }

    private void Save()
    {
        model.LocalUrl = ApiConnectionSettingsStore.NormalizeBaseUrl(model.LocalUrl);
        model.LanUrl = ApiConnectionSettingsStore.NormalizeBaseUrl(model.LanUrl);
        model.HostedUrl = ApiConnectionSettingsStore.NormalizeBaseUrl(model.HostedUrl);

        ConnectionStore.Save(model);
        Startup.Reset();
        activeUrl = ConnectionStore.CurrentBaseUrl;
        statusIsError = false;
        statusMessage = $"Saved. Automatic local startup is now using {model.StartupProfile} -> {activeUrl}";
    }

    private async Task TestConnection()
    {
        isTesting = true;
        statusMessage = null;

        try
        {
            Save();
            lastHealth = await Connectivity.CheckAsync();
            runtime = lastHealth.Runtime;
            statusIsError = !lastHealth.IsHealthy;
            statusMessage = lastHealth.Message;
        }
        catch (Exception exception)
        {
            runtime = null;
            lastHealth = null;
            statusIsError = true;
            statusMessage = $"Connection test failed. Details: {exception.Message}";
        }
        finally
        {
            isTesting = false;
        }
    }

    private async Task StartManagedLocalApi()
    {
        Save();
        await TestConnection();
    }

    private async Task StopManagedLocalApi()
    {
        await LocalApiProcess.StopAsync();
        runtime = null;
        lastHealth = null;
        statusIsError = false;
        statusMessage = "Managed local API process was stopped.";
    }
}
