@page "/reports"
@using QuickBooksClone.Maui.Contracts.Reports
@using QuickBooksClone.Maui.Services.Reports
@inject ReportsApiClient ReportsApi

<PageTitle>Reports</PageTitle>

<div class="qb-page">
    <section class="qb-header">
        <div>
            <p class="eyebrow">Reports</p>
            <h1>Financial Reports</h1>
            <p class="muted">Start with trial balance from posted accounting entries, then grow into full statements and aging reports.</p>
        </div>
        <button class="secondary-button" @onclick="LoadAsync" disabled="@isLoading">Refresh</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <section class="qb-grid">
        <div class="panel">
            <div class="toolbar">
                <label class="form-label">
                    <span>Report</span>
                    <select class="form-control narrow-control" @bind="selectedReport">
                        <option value="@ReportMode.TrialBalance">Trial Balance</option>
                        <option value="@ReportMode.BalanceSheet">Balance Sheet</option>
                        <option value="@ReportMode.ProfitAndLoss">Profit &amp; Loss</option>
                        <option value="@ReportMode.AccountsReceivableAging">A/R Aging</option>
                        <option value="@ReportMode.AccountsPayableAging">A/P Aging</option>
                        <option value="@ReportMode.InventoryValuation">Inventory Valuation / Stock Movement</option>
                    </select>
                </label>
                @if (selectedReport is ReportMode.ProfitAndLoss or ReportMode.InventoryValuation)
                {
                    <label class="form-label">
                        <span>From date</span>
                        <input class="form-control narrow-control" type="date" value="@fromDateText" @onchange="OnFromDateChanged" />
                    </label>
                    <label class="form-label">
                        <span>To date</span>
                        <input class="form-control narrow-control" type="date" value="@toDateText" @onchange="OnToDateChanged" />
                    </label>
                }
                else
                {
                    <label class="form-label">
                        <span>As of date</span>
                        <input class="form-control narrow-control" type="date" value="@asOfDateText" @onchange="OnAsOfDateChanged" />
                    </label>
                }
                <label class="check-row">
                    <input type="checkbox" @bind="includeZeroBalances" />
                    Include zero balances
                </label>
                <label class="check-row">
                    <input type="checkbox" @bind="includeInactiveAccounts" />
                    @InactiveLabel
                </label>
                <button class="primary-button" @onclick="LoadAsync" disabled="@isLoading">Run Report</button>
            </div>

            @if (isLoading)
            {
                <p class="muted">Loading report...</p>
            }
            else if (selectedReport == ReportMode.TrialBalance)
            {
                @if (trialBalanceReport is null || trialBalanceReport.Items.Count == 0)
                {
                    <p class="muted">No posted balances found for the selected date yet.</p>
                }
                else
                {
                    <table class="data-table compact-table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Account</th>
                                <th>Type</th>
                                <th>Total Debit</th>
                                <th>Total Credit</th>
                                <th>Closing Debit</th>
                                <th>Closing Credit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in trialBalanceReport.Items)
                            {
                                <tr>
                                    <td><strong>@row.AccountCode</strong></td>
                                    <td>@row.AccountName</td>
                                    <td>@row.AccountType</td>
                                    <td>@row.TotalDebit.ToString("N2")</td>
                                    <td>@row.TotalCredit.ToString("N2")</td>
                                    <td>@row.ClosingDebit.ToString("N2")</td>
                                    <td>@row.ClosingCredit.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="5">Closing totals</th>
                                <th>@trialBalanceReport.TotalDebit.ToString("N2")</th>
                                <th>@trialBalanceReport.TotalCredit.ToString("N2")</th>
                            </tr>
                        </tfoot>
                    </table>
                }
            }
            else if (selectedReport == ReportMode.BalanceSheet)
            {
                @if (balanceSheetReport is null || balanceSheetReport.Sections.All(s => s.Items.Count == 0))
                {
                    <p class="muted">No balance sheet activity found for the selected date yet.</p>
                }
                else
                {
                    @foreach (var reportSection in balanceSheetReport.Sections)
                    {
                        <div class="totals-box">
                            <strong>@reportSection.Title</strong>
                        </div>

                        <table class="data-table compact-table">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Account</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in reportSection.Items)
                                {
                                    <tr>
                                        <td><strong>@row.AccountCode</strong></td>
                                        <td>@row.AccountName</td>
                                        <td>@row.AccountType</td>
                                        <td>@row.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="3">@reportSection.Title total</th>
                                    <th>@reportSection.Total.ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                }
            }
            else if (selectedReport == ReportMode.ProfitAndLoss)
            {
                @if (profitAndLossReport is null || profitAndLossReport.Sections.All(s => s.Items.Count == 0))
                {
                    <p class="muted">No profit and loss activity found for the selected period yet.</p>
                }
                else
                {
                    @foreach (var reportSection in profitAndLossReport.Sections)
                    {
                        <div class="totals-box">
                            <strong>@reportSection.Title</strong>
                        </div>

                        <table class="data-table compact-table">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Account</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in reportSection.Items)
                                {
                                    <tr>
                                        <td><strong>@row.AccountCode</strong></td>
                                        <td>@row.AccountName</td>
                                        <td>@row.AccountType</td>
                                        <td>@row.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="3">@reportSection.Title total</th>
                                    <th>@reportSection.Total.ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                }
            }
            else
            {
                @if (selectedReport == ReportMode.AccountsReceivableAging)
                {
                    @if (accountsReceivableAgingReport is null || accountsReceivableAgingReport.Items.Count == 0)
                    {
                        <p class="muted">No open receivables found for the selected date yet.</p>
                    }
                    else
                    {
                        <table class="data-table compact-table">
                            <thead>
                                <tr>
                                    <th>Customer</th>
                                    <th>Currency</th>
                                    <th>Current</th>
                                    <th>1-30</th>
                                    <th>31-60</th>
                                    <th>61-90</th>
                                    <th>90+</th>
                                    <th>Total</th>
                                    <th>Credit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in accountsReceivableAgingReport.Items)
                                {
                                    <tr>
                                        <td>
                                            <strong>@row.CustomerName</strong>
                                            <small>@row.OpenInvoiceCount open invoices</small>
                                        </td>
                                        <td>@row.Currency</td>
                                        <td>@row.Current.ToString("N2")</td>
                                        <td>@row.Days1To30.ToString("N2")</td>
                                        <td>@row.Days31To60.ToString("N2")</td>
                                        <td>@row.Days61To90.ToString("N2")</td>
                                        <td>@row.Over90.ToString("N2")</td>
                                        <td>@row.Total.ToString("N2")</td>
                                        <td>@row.CreditBalance.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="2">Totals</th>
                                    <th>@accountsReceivableAgingReport.Current.ToString("N2")</th>
                                    <th>@accountsReceivableAgingReport.Days1To30.ToString("N2")</th>
                                    <th>@accountsReceivableAgingReport.Days31To60.ToString("N2")</th>
                                    <th>@accountsReceivableAgingReport.Days61To90.ToString("N2")</th>
                                    <th>@accountsReceivableAgingReport.Over90.ToString("N2")</th>
                                    <th>@accountsReceivableAgingReport.Total.ToString("N2")</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                }
                else if (selectedReport == ReportMode.AccountsPayableAging)
                {
                    @if (accountsPayableAgingReport is null || accountsPayableAgingReport.Items.Count == 0)
                    {
                        <p class="muted">No open payables found for the selected date yet.</p>
                    }
                    else
                    {
                        <table class="data-table compact-table">
                            <thead>
                                <tr>
                                    <th>Vendor</th>
                                    <th>Currency</th>
                                    <th>Current</th>
                                    <th>1-30</th>
                                    <th>31-60</th>
                                    <th>61-90</th>
                                    <th>90+</th>
                                    <th>Total</th>
                                    <th>Credit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in accountsPayableAgingReport.Items)
                                {
                                    <tr>
                                        <td>
                                            <strong>@row.VendorName</strong>
                                            <small>@row.OpenBillCount open bills</small>
                                        </td>
                                        <td>@row.Currency</td>
                                        <td>@row.Current.ToString("N2")</td>
                                        <td>@row.Days1To30.ToString("N2")</td>
                                        <td>@row.Days31To60.ToString("N2")</td>
                                        <td>@row.Days61To90.ToString("N2")</td>
                                        <td>@row.Over90.ToString("N2")</td>
                                        <td>@row.Total.ToString("N2")</td>
                                        <td>@row.CreditBalance.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="2">Totals</th>
                                    <th>@accountsPayableAgingReport.Current.ToString("N2")</th>
                                    <th>@accountsPayableAgingReport.Days1To30.ToString("N2")</th>
                                    <th>@accountsPayableAgingReport.Days31To60.ToString("N2")</th>
                                    <th>@accountsPayableAgingReport.Days61To90.ToString("N2")</th>
                                    <th>@accountsPayableAgingReport.Over90.ToString("N2")</th>
                                    <th>@accountsPayableAgingReport.Total.ToString("N2")</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                }
                else
                {
                    @if (inventoryValuationReport is null || inventoryValuationReport.Items.Count == 0)
                    {
                        <p class="muted">No inventory movement found for the selected period yet.</p>
                    }
                    else
                    {
                        <table class="data-table compact-table">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>SKU</th>
                                    <th>Unit</th>
                                    <th>Unit Cost</th>
                                    <th>Opening Qty</th>
                                    <th>In</th>
                                    <th>Out</th>
                                    <th>Closing Qty</th>
                                    <th>Opening Value</th>
                                    <th>In Value</th>
                                    <th>Out Value</th>
                                    <th>Closing Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in inventoryValuationReport.Items)
                                {
                                    <tr>
                                        <td><strong>@row.ItemName</strong></td>
                                        <td>@(string.IsNullOrWhiteSpace(row.Sku) ? "-" : row.Sku)</td>
                                        <td>@row.Unit</td>
                                        <td>@row.UnitCost.ToString("N2")</td>
                                        <td>@row.OpeningQuantity.ToString("N2")</td>
                                        <td>@row.QuantityIn.ToString("N2")</td>
                                        <td>@row.QuantityOut.ToString("N2")</td>
                                        <td>@row.ClosingQuantity.ToString("N2")</td>
                                        <td>@row.OpeningValue.ToString("N2")</td>
                                        <td>@row.QuantityInValue.ToString("N2")</td>
                                        <td>@row.QuantityOutValue.ToString("N2")</td>
                                        <td>@row.ClosingValue.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="4">Totals</th>
                                    <th>@inventoryValuationReport.TotalOpeningQuantity.ToString("N2")</th>
                                    <th>@inventoryValuationReport.TotalQuantityIn.ToString("N2")</th>
                                    <th>@inventoryValuationReport.TotalQuantityOut.ToString("N2")</th>
                                    <th>@inventoryValuationReport.TotalClosingQuantity.ToString("N2")</th>
                                    <th>@inventoryValuationReport.TotalOpeningValue.ToString("N2")</th>
                                    <th>@inventoryValuationReport.TotalQuantityInValue.ToString("N2")</th>
                                    <th>@inventoryValuationReport.TotalQuantityOutValue.ToString("N2")</th>
                                    <th>@inventoryValuationReport.TotalClosingValue.ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                }
            }
        </div>

        <section class="panel form-panel">
            <h2>Report Roadmap</h2>
            <div class="metric-grid">
                <div class="metric-box">
                    <span>Live now</span>
                    <strong>Trial Balance / Balance Sheet / P&amp;L</strong>
                </div>
                <div class="metric-box">
                    <span>Next</span>
                    <strong>A/R, A/P, and Inventory Live</strong>
                </div>
                <div class="metric-box">
                    <span>Then</span>
                    <strong>Review + Hardening</strong>
                </div>
            </div>

            <div class="totals-box">
                Reports should come from posted accounting entries only, not from ad hoc UI totals.
            </div>

            @if (balanceSheetReport is not null)
            {
                <div class="metric-grid">
                    <div class="metric-box">
                        <span>Total Assets</span>
                        <strong>@balanceSheetReport.TotalAssets.ToString("N2")</strong>
                    </div>
                    <div class="metric-box">
                        <span>Liabilities</span>
                        <strong>@balanceSheetReport.TotalLiabilities.ToString("N2")</strong>
                    </div>
                    <div class="metric-box">
                        <span>Equity</span>
                        <strong>@balanceSheetReport.TotalEquity.ToString("N2")</strong>
                    </div>
                </div>
            }

            @if (profitAndLossReport is not null)
            {
                <div class="metric-grid">
                    <div class="metric-box">
                        <span>Total Income</span>
                        <strong>@profitAndLossReport.TotalIncome.ToString("N2")</strong>
                    </div>
                    <div class="metric-box">
                        <span>Gross Profit</span>
                        <strong>@profitAndLossReport.GrossProfit.ToString("N2")</strong>
                    </div>
                    <div class="metric-box">
                        <span>Net Profit</span>
                        <strong>@profitAndLossReport.NetProfit.ToString("N2")</strong>
                    </div>
                </div>
            }

            @if (accountsReceivableAgingReport is not null)
            {
                <div class="metric-grid">
                    <div class="metric-box">
                        <span>Current</span>
                        <strong>@accountsReceivableAgingReport.Current.ToString("N2")</strong>
                    </div>
                    <div class="metric-box">
                        <span>Over 30</span>
                        <strong>@((accountsReceivableAgingReport.Days31To60 + accountsReceivableAgingReport.Days61To90 + accountsReceivableAgingReport.Over90).ToString("N2"))</strong>
                    </div>
                    <div class="metric-box">
                        <span>Total A/R</span>
                        <strong>@accountsReceivableAgingReport.Total.ToString("N2")</strong>
                    </div>
                </div>
            }

            @if (accountsPayableAgingReport is not null)
            {
                <div class="metric-grid">
                    <div class="metric-box">
                        <span>A/P Current</span>
                        <strong>@accountsPayableAgingReport.Current.ToString("N2")</strong>
                    </div>
                    <div class="metric-box">
                        <span>A/P Over 30</span>
                        <strong>@((accountsPayableAgingReport.Days31To60 + accountsPayableAgingReport.Days61To90 + accountsPayableAgingReport.Over90).ToString("N2"))</strong>
                    </div>
                    <div class="metric-box">
                        <span>Total A/P</span>
                        <strong>@accountsPayableAgingReport.Total.ToString("N2")</strong>
                    </div>
                </div>
            }

            @if (inventoryValuationReport is not null)
            {
                <div class="metric-grid">
                    <div class="metric-box">
                        <span>Opening Value</span>
                        <strong>@inventoryValuationReport.TotalOpeningValue.ToString("N2")</strong>
                    </div>
                    <div class="metric-box">
                        <span>Period Movement</span>
                        <strong>@((inventoryValuationReport.TotalQuantityInValue - inventoryValuationReport.TotalQuantityOutValue).ToString("N2"))</strong>
                    </div>
                    <div class="metric-box">
                        <span>Closing Value</span>
                        <strong>@inventoryValuationReport.TotalClosingValue.ToString("N2")</strong>
                    </div>
                </div>
            }

            <ul class="check-list">
                <li>Trial balance is calculated from posted transactions up to the selected date.</li>
                <li>Voided accounting transactions are excluded automatically.</li>
                <li>Balance sheet groups balance-sheet accounts into assets, liabilities, and equity from the same posted ledger.</li>
                <li>Profit and loss uses a date range and separates income, COGS, and expenses from the same posted ledger.</li>
                <li>A/R aging groups open credit invoices by customer and due-date bucket using the current open balance only.</li>
                <li>A/P aging groups open vendor bills by due-date bucket using the current open payable balance only.</li>
                <li>Inventory valuation combines posted stock movement documents with current item on-hand quantities.</li>
                <li>Current inventory valuation uses the item's current purchase price for opening and closing value until costing layers ship.</li>
            </ul>
        </section>
    </section>
</div>

@code {
    private TrialBalanceReportDto? trialBalanceReport;
    private BalanceSheetReportDto? balanceSheetReport;
    private ProfitAndLossReportDto? profitAndLossReport;
    private AccountsReceivableAgingReportDto? accountsReceivableAgingReport;
    private AccountsPayableAgingReportDto? accountsPayableAgingReport;
    private InventoryValuationReportDto? inventoryValuationReport;
    private string asOfDateText = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    private string fromDateText = new DateOnly(DateTime.Today.Year, 1, 1).ToString("yyyy-MM-dd");
    private string toDateText = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    private string? errorMessage;
    private bool includeZeroBalances;
    private bool includeInactiveAccounts;
    private bool isLoading;
    private ReportMode selectedReport = ReportMode.TrialBalance;

    private string InactiveLabel =>
        selectedReport switch
        {
            ReportMode.AccountsReceivableAging => "Include inactive customers",
            ReportMode.AccountsPayableAging => "Include inactive vendors",
            ReportMode.InventoryValuation => "Include inactive items",
            _ => "Include inactive accounts"
        };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            errorMessage = null;
            isLoading = true;
            var asOfDate = ParseAsOfDate();

            if (selectedReport == ReportMode.TrialBalance)
            {
                trialBalanceReport = await ReportsApi.GetTrialBalanceAsync(asOfDate, includeZeroBalances, includeInactiveAccounts);
            }
            else if (selectedReport == ReportMode.BalanceSheet)
            {
                balanceSheetReport = await ReportsApi.GetBalanceSheetAsync(asOfDate, includeZeroBalances, includeInactiveAccounts);
            }
            else
            {
                if (selectedReport == ReportMode.ProfitAndLoss)
                {
                    profitAndLossReport = await ReportsApi.GetProfitAndLossAsync(ParseFromDate(), ParseToDate(), includeZeroBalances, includeInactiveAccounts);
                }
                else if (selectedReport == ReportMode.AccountsReceivableAging)
                {
                    accountsReceivableAgingReport = await ReportsApi.GetAccountsReceivableAgingAsync(asOfDate, includeZeroBalances, includeInactiveAccounts);
                }
                else if (selectedReport == ReportMode.AccountsPayableAging)
                {
                    accountsPayableAgingReport = await ReportsApi.GetAccountsPayableAgingAsync(asOfDate, includeZeroBalances, includeInactiveAccounts);
                }
                else
                {
                    inventoryValuationReport = await ReportsApi.GetInventoryValuationAsync(ParseFromDate(), ParseToDate(), includeZeroBalances, includeInactiveAccounts);
                }
            }
        }
        catch (Exception exception)
        {
            errorMessage = $"Could not load reports. Details: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private DateOnly ParseAsOfDate()
    {
        return DateOnly.TryParse(asOfDateText, out var parsed)
            ? parsed
            : DateOnly.FromDateTime(DateTime.Today);
    }

    private DateOnly ParseFromDate()
    {
        return DateOnly.TryParse(fromDateText, out var parsed)
            ? parsed
            : new DateOnly(DateTime.Today.Year, 1, 1);
    }

    private DateOnly ParseToDate()
    {
        return DateOnly.TryParse(toDateText, out var parsed)
            ? parsed
            : DateOnly.FromDateTime(DateTime.Today);
    }

    private void OnAsOfDateChanged(ChangeEventArgs args)
    {
        asOfDateText = args.Value?.ToString() ?? asOfDateText;
    }

    private void OnFromDateChanged(ChangeEventArgs args)
    {
        fromDateText = args.Value?.ToString() ?? fromDateText;
    }

    private void OnToDateChanged(ChangeEventArgs args)
    {
        toDateText = args.Value?.ToString() ?? toDateText;
    }

    private enum ReportMode
    {
        TrialBalance,
        BalanceSheet,
        ProfitAndLoss,
        AccountsReceivableAging,
        AccountsPayableAging,
        InventoryValuation
    }
}
