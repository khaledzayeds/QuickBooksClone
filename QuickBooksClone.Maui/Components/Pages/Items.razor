@page "/items"
@inject ItemsApiClient ItemsApi
@inject NavigationManager Navigation

<PageTitle>Items</PageTitle>

<div class="qb-page">
    <section class="qb-header">
        <div>
            <p class="eyebrow">Inventory</p>
            <h1>Items</h1>
            <p class="muted">Products and services used by invoices and posting.</p>
        </div>
        <button class="primary-button" @onclick="NewItem">New Item</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <section class="panel">
        <div class="toolbar">
            <input class="search-input" placeholder="Search by name, SKU, barcode, type" @bind="searchText" @bind:event="oninput" />
            <label class="check-row">
                <input type="checkbox" @bind="includeInactive" />
                Include inactive
            </label>
            <button class="secondary-button" @onclick="LoadItemsAsync" disabled="@isLoading">Search</button>
        </div>

        @if (isLoading)
        {
            <p class="muted">Loading items...</p>
        }
        else if (items.Count == 0)
        {
            <p class="muted">No items found.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Type</th>
                        <th>SKU</th>
                        <th>Sales</th>
                        <th>Cost</th>
                        <th>Qty</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                                <small>@item.Id.ToString()[..8]</small>
                            </td>
                            <td>@item.ItemType</td>
                            <td>
                                <span>@item.Sku</span>
                                <small>@item.Barcode</small>
                            </td>
                            <td>@item.SalesPrice.ToString("N2")</td>
                            <td>@item.PurchasePrice.ToString("N2")</td>
                            <td>@item.QuantityOnHand.ToString("N2") @item.Unit</td>
                            <td>
                                <span class="status @(item.IsActive ? "active" : "inactive")">
                                    @(item.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="actions">
                                <button class="link-button" @onclick="() => EditItem(item.Id)">Edit</button>
                                <button class="link-button" @onclick="() => ToggleActiveAsync(item)">
                                    @(item.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private List<ItemDto> items = [];
    private string? searchText;
    private string? errorMessage;
    private bool includeInactive;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadItemsAsync();
    }

    private async Task LoadItemsAsync()
    {
        try
        {
            errorMessage = null;
            isLoading = true;
            var result = await ItemsApi.SearchAsync(searchText, includeInactive);
            items = result.Items.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load items. Make sure the API is running on http://localhost:5014. Details: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleActiveAsync(ItemDto item)
    {
        try
        {
            errorMessage = null;
            await ItemsApi.SetActiveAsync(item.Id, !item.IsActive);
            await LoadItemsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not update item status. Details: {ex.Message}";
        }
    }

    private void NewItem()
    {
        Navigation.NavigateTo("items/new");
    }

    private void EditItem(Guid itemId)
    {
        Navigation.NavigateTo($"items/{itemId}/edit");
    }
}
