@page "/accounts"
@inject AccountsApiClient AccountsApi

<PageTitle>Chart of Accounts</PageTitle>

<div class="qb-page">
    <section class="qb-header">
        <div>
            <p class="eyebrow">Accounting</p>
            <h1>Chart of Accounts</h1>
            <p class="muted">The accounts that invoices, items, payments, and posting will use.</p>
        </div>
        <button class="primary-button" @onclick="NewAccount">New Account</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <section class="qb-grid">
        <div class="panel">
            <div class="toolbar">
                <input class="search-input" placeholder="Search by code, name, type" @bind="searchText" @bind:event="oninput" />
                <select class="form-control narrow-control" @bind="accountTypeFilter">
                    <option value="">All types</option>
                    @foreach (var type in AccountTypes)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
                <label class="check-row">
                    <input type="checkbox" @bind="includeInactive" />
                    Include inactive
                </label>
                <button class="secondary-button" @onclick="LoadAccountsAsync" disabled="@isLoading">Search</button>
            </div>

            @if (isLoading)
            {
                <p class="muted">Loading accounts...</p>
            }
            else if (accounts.Count == 0)
            {
                <p class="muted">No accounts found.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var account in accounts)
                        {
                            <tr class="@(selectedAccount?.Id == account.Id ? "selected" : null)">
                                <td><strong>@account.Code</strong></td>
                                <td>
                                    @account.Name
                                    <small>@account.Id.ToString()[..8]</small>
                                </td>
                                <td>@account.AccountType</td>
                                <td>@account.Description</td>
                                <td>
                                    <span class="status @(account.IsActive ? "active" : "inactive")">
                                        @(account.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="actions">
                                    <button class="link-button" @onclick="() => EditAccount(account)">Edit</button>
                                    <button class="link-button" @onclick="() => ToggleActiveAsync(account)">
                                        @(account.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <EditForm Model="form" OnValidSubmit="SaveAccountAsync" class="panel form-panel">
            <DataAnnotationsValidator />

            <h2>@(selectedAccount is null ? "New Account" : "Edit Account")</h2>
            <p class="muted">Next slice will connect item income, inventory, and COGS accounts.</p>

            <div class="form-row">
                <label>
                    Code
                    <InputText class="form-control" @bind-Value="form.Code" />
                    <ValidationMessage For="@(() => form.Code)" />
                </label>

                <label>
                    Type
                    <InputSelect class="form-control" @bind-Value="form.AccountType">
                        @foreach (var type in AccountTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </InputSelect>
                </label>
            </div>

            <label>
                Name
                <InputText class="form-control" @bind-Value="form.Name" />
                <ValidationMessage For="@(() => form.Name)" />
            </label>

            <label>
                Parent account
                <InputSelect class="form-control" @bind-Value="form.ParentId">
                    <option value="">None</option>
                    @foreach (var account in accounts.Where(account => selectedAccount?.Id != account.Id))
                    {
                        <option value="@account.Id">@account.Code - @account.Name</option>
                    }
                </InputSelect>
            </label>

            <label>
                Description
                <InputTextArea class="form-control" @bind-Value="form.Description" />
            </label>

            <div class="form-actions">
                <button class="primary-button" type="submit" disabled="@isSaving">
                    @(isSaving ? "Saving..." : selectedAccount is null ? "Create" : "Save")
                </button>
                <button class="secondary-button" type="button" @onclick="NewAccount">Clear</button>
            </div>
        </EditForm>
    </section>
</div>

@code {
    private static readonly AccountType[] AccountTypes = Enum.GetValues<AccountType>();

    private List<AccountDto> accounts = [];
    private AccountDto? selectedAccount;
    private AccountFormModel form = new();
    private string? searchText;
    private string? accountTypeFilter;
    private string? errorMessage;
    private bool includeInactive;
    private bool isLoading;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccountsAsync();
    }

    private async Task LoadAccountsAsync()
    {
        try
        {
            errorMessage = null;
            isLoading = true;
            var type = Enum.TryParse<AccountType>(accountTypeFilter, out var parsedType) ? parsedType : (AccountType?)null;
            var result = await AccountsApi.SearchAsync(searchText, type, includeInactive);
            accounts = result.Items.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load accounts. Make sure the API is running on http://localhost:5014. Details: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NewAccount()
    {
        selectedAccount = null;
        form = new AccountFormModel();
        errorMessage = null;
    }

    private void EditAccount(AccountDto account)
    {
        selectedAccount = account;
        form = AccountFormModel.FromAccount(account);
        errorMessage = null;
    }

    private async Task SaveAccountAsync()
    {
        try
        {
            errorMessage = null;
            isSaving = true;

            if (selectedAccount is null)
            {
                await AccountsApi.CreateAsync(form);
            }
            else
            {
                await AccountsApi.UpdateAsync(selectedAccount.Id, form);
            }

            NewAccount();
            await LoadAccountsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not save account. Details: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleActiveAsync(AccountDto account)
    {
        try
        {
            errorMessage = null;
            await AccountsApi.SetActiveAsync(account.Id, !account.IsActive);
            await LoadAccountsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not update account status. Details: {ex.Message}";
        }
    }
}
