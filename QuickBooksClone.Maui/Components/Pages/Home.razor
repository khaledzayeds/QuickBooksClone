@page "/"
@using QuickBooksClone.Maui.Services
@using QuickBooksClone.Maui.Services.Settings
@inject ApiConnectionSettingsStore ConnectionStore
@inject ApiConnectivityService Connectivity

<h1>QuickBooksClone Desktop</h1>

<p>Start with the first working slice: customers.</p>
<p class="muted">Startup mode: @ConnectionStore.Current.StartupMode | Active API profile: @ConnectionStore.Current.StartupProfile -> @ConnectionStore.CurrentBaseUrl</p>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="panel status-panel @(statusIsError ? "status-error" : "status-success")">
        @statusMessage
    </div>
}

<p>
    <a class="btn btn-primary" href="customers">Open Customers</a>
    <a class="btn btn-secondary" href="accounts">Open Accounts</a>
    <a class="btn btn-secondary" href="items">Open Items</a>
    <a class="btn btn-secondary" href="invoices">Open Invoices</a>
    <a class="btn btn-secondary" href="connection-settings">Connection Settings</a>
</p>

@code {
    private string? statusMessage;
    private bool statusIsError;

    protected override async Task OnInitializedAsync()
    {
        var result = await Connectivity.CheckAsync();
        statusMessage = result.Message;
        statusIsError = !result.IsHealthy;
    }
}
