@page "/"
@using QuickBooksClone.Maui.Services
@using QuickBooksClone.Maui.Services.Settings
@inject ApiConnectionSettingsStore ConnectionStore
@inject ApiConnectivityService Connectivity
@inject NavigationManager Navigation

<PageTitle>Home</PageTitle>

<div class="qb-page">
    <section class="qb-header">
        <div>
            <p class="eyebrow">Operations</p>
            <h1>QuickBooks Workflow Home</h1>
            <p class="muted">Run the business from left to right, open the live workflows now, and see exactly what is next in development.</p>
        </div>
        <div class="home-header-actions">
            <a class="secondary-button" href="connection-settings">Connection Settings</a>
            <a class="primary-button" href="transactions">Transactions</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="panel status-panel @(statusIsError ? "status-error" : "status-success")">
            @statusMessage
        </div>
    }

    <section class="home-overview-grid">
        <div class="metric-box">
            <span>Startup Mode</span>
            <strong>@ConnectionStore.Current.StartupMode</strong>
        </div>
        <div class="metric-box">
            <span>Active Profile</span>
            <strong>@ConnectionStore.Current.StartupProfile</strong>
        </div>
        <div class="metric-box">
            <span>Active API</span>
            <strong>@ConnectionStore.CurrentBaseUrl</strong>
        </div>
        <div class="metric-box">
            <span>Current Direction</span>
            <strong>Workflow-by-workflow</strong>
        </div>
    </section>

    <div class="home-grid">
        <section class="home-band">
            <div class="home-band-header">
                <div>
                    <p class="eyebrow">Vendors</p>
                    <h2>Purchase Side</h2>
                    <p class="muted">Move from planning purchases to receiving stock, vendor bills, and vendor settlement.</p>
                </div>
            </div>
            <div class="workflow-lane">
                @for (var index = 0; index < VendorSteps.Count; index++)
                {
                    var step = VendorSteps[index];
                    <button class="@GetWorkflowStepClass(step)" @onclick="() => OpenStep(step)">
                        <span class="workflow-step-state">@GetStateLabel(step)</span>
                        <strong>@step.Title</strong>
                        <small>@step.Description</small>
                    </button>

                    @if (index < VendorSteps.Count - 1)
                    {
                        <span class="workflow-arrow" aria-hidden="true">→</span>
                    }
                }
            </div>
        </section>

        <section class="home-band">
            <div class="home-band-header">
                <div>
                    <p class="eyebrow">Customers</p>
                    <h2>Sales Side</h2>
                    <p class="muted">Start with quoting and orders, then invoice, collect, credit, refund, and review customer activity.</p>
                </div>
            </div>
            <div class="workflow-lane">
                @for (var index = 0; index < CustomerSteps.Count; index++)
                {
                    var step = CustomerSteps[index];
                    <button class="@GetWorkflowStepClass(step)" @onclick="() => OpenStep(step)">
                        <span class="workflow-step-state">@GetStateLabel(step)</span>
                        <strong>@step.Title</strong>
                        <small>@step.Description</small>
                    </button>

                    @if (index < CustomerSteps.Count - 1)
                    {
                        <span class="workflow-arrow" aria-hidden="true">→</span>
                    }
                }
            </div>
        </section>

        <section class="home-band">
            <div class="home-band-header">
                <div>
                    <p class="eyebrow">Banking</p>
                    <h2>Cash and Bank Controls</h2>
                    <p class="muted">Use the live receipts and payments now, then extend into deposits, checks, registers, and reconciliation.</p>
                </div>
            </div>
            <div class="workflow-lane">
                @for (var index = 0; index < BankingSteps.Count; index++)
                {
                    var step = BankingSteps[index];
                    <button class="@GetWorkflowStepClass(step)" @onclick="() => OpenStep(step)">
                        <span class="workflow-step-state">@GetStateLabel(step)</span>
                        <strong>@step.Title</strong>
                        <small>@step.Description</small>
                    </button>

                    @if (index < BankingSteps.Count - 1)
                    {
                        <span class="workflow-arrow" aria-hidden="true">→</span>
                    }
                }
            </div>
        </section>

        <section class="home-side-panel">
            <div class="panel">
                <div class="toolbar">
                    <strong>Company</strong>
                </div>
                <div class="home-shortcuts">
                    @foreach (var step in CompanySteps)
                    {
                        <button class="@GetWorkflowStepClass(step)" @onclick="() => OpenStep(step)">
                            <span class="workflow-step-state">@GetStateLabel(step)</span>
                            <strong>@step.Title</strong>
                            <small>@step.Description</small>
                        </button>
                    }
                </div>
            </div>

            <div class="panel">
                <div class="toolbar">
                    <strong>Current Coverage</strong>
                </div>
                <ul class="home-checklist">
                    <li>Opening balances, posting engine, subledgers, and reversals are live.</li>
                    <li>Sales invoices, customer payments, returns, and credits are live.</li>
                    <li>Vendor bills, vendor payments, returns, and credits are live.</li>
                    <li>Inventory adjustments and manual journal entries are live.</li>
                    <li>Purchase orders, sales orders, estimates, statements, and bank reconciliation are next.</li>
                </ul>
            </div>
        </section>
    </div>
</div>

@code {
    private string? statusMessage;
    private bool statusIsError;

    private IReadOnlyList<WorkflowStep> VendorSteps => new[]
    {
        new WorkflowStep("Purchase Orders", "Plan what will be ordered before stock or payables move.", "purchase-orders", true, null),
        new WorkflowStep("Receive Inventory", "Receive stock into inventory before the final vendor bill arrives.", null, false, "Will follow purchase orders and inventory receiving logic."),
        new WorkflowStep("Enter Bills", "Record vendor bills and post inventory/expense into Accounts Payable.", "purchase-bills", true, null),
        new WorkflowStep("Pay Bills", "Pay posted bills and reduce vendor balances from cash or bank.", "vendor-payments", true, null),
        new WorkflowStep("Vendor Returns", "Return goods, create vendor credits, and receive refunds when needed.", "purchase-returns", true, null)
    };

    private IReadOnlyList<WorkflowStep> CustomerSteps => new[]
    {
        new WorkflowStep("Estimates", "Quote customers before sales become real commitments.", null, false, "Estimate workflow is queued for development."),
        new WorkflowStep("Sales Orders", "Track committed orders before invoicing and fulfillment.", null, false, "Sales order workflow is queued after estimates."),
        new WorkflowStep("Create Invoices", "Create draft, credit, or cash invoices and auto-post operational sales.", "invoices", true, null),
        new WorkflowStep("Receive Payments", "Receive customer payments and settle Accounts Receivable.", "payments", true, null),
        new WorkflowStep("Sales Receipts", "Instant sale plus payment in one customer-side workflow.", "invoices/new", true, "Use cash invoices now; dedicated sales receipt screen can come later."),
        new WorkflowStep("Refunds and Credits", "Handle sales returns, customer credits, and customer refunds.", "customer-credits", true, null),
        new WorkflowStep("Statements", "Summarize customer activity and outstanding balances across periods.", null, false, "Customer statements and statement charges are still planned.")
    };

    private IReadOnlyList<WorkflowStep> BankingSteps => new[]
    {
        new WorkflowStep("Record Deposits", "Group cash and receipt activity into bank deposits.", null, false, "Bank deposit batching is still planned."),
        new WorkflowStep("Write Checks", "Create direct outgoing bank payments outside vendor bill flow.", null, false, "Write check workflow is still planned."),
        new WorkflowStep("Check Register", "Review bank activity in one running register view.", null, false, "Register view will come with banking workflows."),
        new WorkflowStep("Reconcile", "Match books against the bank statement and clear differences.", null, false, "Bank reconciliation is still planned."),
        new WorkflowStep("Journal Entries", "Post manual balanced entries for reclassification and cleanup.", "journal-entries", true, null)
    };

    private IReadOnlyList<WorkflowStep> CompanySteps => new[]
    {
        new WorkflowStep("Chart of Accounts", "Review account balances and maintain the accounting tree.", "accounts", true, null),
        new WorkflowStep("Items and Services", "Maintain sellable, purchasable, service, and inventory items.", "items", true, null),
        new WorkflowStep("Customers", "Manage customer master data and opening balances.", "customers", true, null),
        new WorkflowStep("Vendors", "Manage vendor master data and opening balances.", "vendors", true, null),
        new WorkflowStep("Inventory Activity", "Review stock-impact workflows and direct adjustments.", "inventory-adjustments", true, null),
        new WorkflowStep("Reports", "Financial, customer, vendor, inventory, and management reporting.", null, false, "Reports foundation is a major upcoming backend slice.")
    };

    protected override async Task OnInitializedAsync()
    {
        var result = await Connectivity.CheckAsync();
        statusMessage = result.Message;
        statusIsError = !result.IsHealthy;
    }

    private void OpenStep(WorkflowStep step)
    {
        if (step.IsAvailable && !string.IsNullOrWhiteSpace(step.Route))
        {
            Navigation.NavigateTo(step.Route);
            return;
        }

        statusIsError = false;
        statusMessage = $"{step.Title} is planned next. {step.PlannedNote}";
    }

    private static string GetWorkflowStepClass(WorkflowStep step) =>
        step.IsAvailable ? "workflow-step workflow-step-live" : "workflow-step workflow-step-planned";

    private static string GetStateLabel(WorkflowStep step) => step.IsAvailable ? "Live now" : "Planned";

    private sealed record WorkflowStep(
        string Title,
        string Description,
        string? Route,
        bool IsAvailable,
        string? PlannedNote);
}
