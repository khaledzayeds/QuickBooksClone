@page "/purchase-bills/new"
@inject PurchaseBillsApiClient PurchaseBillsApi
@inject VendorsApiClient VendorsApi
@inject ItemsApiClient ItemsApi
@inject InventoryReceiptsApiClient InventoryReceiptsApi
@inject NavigationManager Navigation
@using QuickBooksClone.Maui.Services.PurchaseBills
@using QuickBooksClone.Maui.Services.ReceiveInventory
@using Microsoft.AspNetCore.Components

<PageTitle>New Purchase Bill</PageTitle>

<div class="qb-page">
    <section class="qb-header">
        <div>
            <p class="eyebrow">Purchases</p>
            <h1>New Purchase Bill</h1>
            <p class="muted">Record Accounts Payable now. If this bill is tied to received inventory, it clears GRNI instead of increasing stock again.</p>
        </div>
        <button class="secondary-button" @onclick="BackToList">Back to Bills</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <EditForm Model="form" class="panel form-panel page-form page-form-wide">
        <DataAnnotationsValidator />

        @if (linkedReceipt is not null)
        {
            <div class="alert success">
                Billing against receipt <strong>@linkedReceipt.ReceiptNumber</strong>. Stock already moved on receipt; this bill will clear GRNI into Accounts Payable.
            </div>
        }

        <div class="form-row">
            <label>
                Vendor
                <InputSelect class="form-control" @bind-Value="form.VendorId" disabled="@IsReceiptLocked">
                    <option value="@Guid.Empty">Select vendor</option>
                    @foreach (var vendor in vendors)
                    {
                        <option value="@vendor.Id">@vendor.DisplayName</option>
                    }
                </InputSelect>
            </label>

            <label>
                Linked receipt
                <input class="form-control" value="@(linkedReceipt?.ReceiptNumber ?? "Direct bill")" disabled />
            </label>
        </div>

        <div class="form-row">
            <label>
                Bill date
                <InputDate class="form-control" @bind-Value="billDate" />
            </label>

            <label>
                Due date
                <InputDate class="form-control" @bind-Value="dueDate" />
            </label>
        </div>

        <h3>Lines</h3>

        @if (linkedReceipt is null)
        {
            <div class="form-row">
                <label>
                    Item
                    <InputSelect class="form-control" @bind-Value="draftLine.ItemId">
                        <option value="@Guid.Empty">Select item</option>
                        @foreach (var item in items)
                        {
                            <option value="@item.Id">@item.Name (@item.PurchasePrice.ToString("N2"))</option>
                        }
                    </InputSelect>
                </label>

                <label>
                    Quantity
                    <InputNumber class="form-control" @bind-Value="draftLine.Quantity" />
                </label>
            </div>

            <div class="form-row">
                <label>
                    Unit cost
                    <InputNumber class="form-control" @bind-Value="draftLine.UnitCost" />
                </label>

                <label>
                    Description
                    <InputText class="form-control" @bind-Value="draftLine.Description" />
                </label>
            </div>

            <button class="secondary-button" type="button" @onclick="AddLine">Add Line</button>
        }
        else if (form.Lines.Count == 0)
        {
            <p class="muted">No remaining receipt lines are available to bill.</p>
        }
        else
        {
            <p class="muted">Quantities are prefilled from the remaining unbilled receipt lines. You can reduce quantity or change unit cost before posting the bill.</p>
        }

        @if (form.Lines.Count > 0)
        {
            <table class="data-table compact-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Qty</th>
                        <th>Cost</th>
                        <th>Total</th>
                        <th>@(linkedReceipt is null ? string.Empty : "Receipt line")</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in form.Lines)
                    {
                        <tr>
                            <td>@GetItemName(line.ItemId)</td>
                            <td>
                                @if (linkedReceipt is null)
                                {
                                    @line.Quantity
                                }
                                else
                                {
                                    <InputNumber class="form-control" @bind-Value="line.Quantity" />
                                }
                            </td>
                            <td>
                                @if (linkedReceipt is null)
                                {
                                    @line.UnitCost.ToString("N2")
                                }
                                else
                                {
                                    <InputNumber class="form-control" @bind-Value="line.UnitCost" />
                                }
                            </td>
                            <td>@((line.Quantity * line.UnitCost).ToString("N2"))</td>
                            <td>@(line.InventoryReceiptLineId?.ToString()[..8] ?? "-")</td>
                            <td><button class="link-button" type="button" @onclick="() => RemoveLine(line)">Remove</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="totals-box">
            Draft total: @DraftTotal.ToString("N2")
        </div>

        <div class="form-actions">
            <button class="primary-button" type="button" disabled="@isSaving" @onclick="() => SaveBillAsync(PurchaseBillSaveMode.SaveAndPost)">
                @(isSaving ? "Saving..." : "Create and Post")
            </button>
            <button class="secondary-button" type="button" disabled="@isSaving" @onclick="() => SaveBillAsync(PurchaseBillSaveMode.Draft)">Save Draft</button>
            <button class="secondary-button" type="button" @onclick="BackToList">Cancel</button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "inventoryReceiptId")]
    public Guid? InventoryReceiptId { get; set; }

    private List<VendorDto> vendors = [];
    private List<ItemDto> items = [];
    private PurchaseBillFormModel form = new();
    private PurchaseBillLineFormModel draftLine = new();
    private InventoryReceiptDto? linkedReceipt;
    private DateTime billDate = DateTime.Today;
    private DateTime dueDate = DateTime.Today.AddDays(30);
    private string? errorMessage;
    private bool isSaving;

    private bool IsReceiptLocked => linkedReceipt is not null;
    private decimal DraftTotal => form.Lines.Sum(line => line.Quantity * line.UnitCost);

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupsAsync();
        if (InventoryReceiptId is not null)
        {
            await LoadReceiptAsync(InventoryReceiptId.Value);
        }
    }

    private async Task LoadLookupsAsync()
    {
        var vendorResult = await VendorsApi.SearchAsync(null, false);
        vendors = vendorResult.Items.ToList();

        var itemResult = await ItemsApi.SearchAsync(null, false);
        items = itemResult.Items.ToList();
    }

    private async Task LoadReceiptAsync(Guid receiptId)
    {
        linkedReceipt = await InventoryReceiptsApi.GetAsync(receiptId);
        form.InventoryReceiptId = linkedReceipt.Id;
        form.VendorId = linkedReceipt.VendorId;

        var existingBills = await PurchaseBillsApi.SearchAsync(null, true, linkedReceipt.Id);
        var billedByReceiptLine = existingBills.Items
            .Where(bill => bill.Status != PurchaseBillStatus.Void)
            .SelectMany(bill => bill.Lines)
            .Where(line => line.InventoryReceiptLineId is not null)
            .GroupBy(line => line.InventoryReceiptLineId!.Value)
            .ToDictionary(group => group.Key, group => group.Sum(line => line.Quantity));

        form.Lines.Clear();
        foreach (var receiptLine in linkedReceipt.Lines)
        {
            var remainingQuantity = receiptLine.Quantity - billedByReceiptLine.GetValueOrDefault(receiptLine.Id);
            if (remainingQuantity <= 0)
            {
                continue;
            }

            form.Lines.Add(new PurchaseBillLineFormModel
            {
                ItemId = receiptLine.ItemId,
                InventoryReceiptLineId = receiptLine.Id,
                Description = receiptLine.Description,
                Quantity = remainingQuantity,
                UnitCost = receiptLine.UnitCost
            });
        }
    }

    private void AddLine()
    {
        if (draftLine.ItemId == Guid.Empty || draftLine.Quantity <= 0)
        {
            errorMessage = "Select an item and enter a quantity greater than zero.";
            return;
        }

        var item = items.FirstOrDefault(current => current.Id == draftLine.ItemId);
        var unitCost = draftLine.UnitCost > 0 ? draftLine.UnitCost : item?.PurchasePrice ?? 0;

        form.Lines.Add(new PurchaseBillLineFormModel
        {
            ItemId = draftLine.ItemId,
            Description = string.IsNullOrWhiteSpace(draftLine.Description) ? item?.Name : draftLine.Description,
            Quantity = draftLine.Quantity,
            UnitCost = unitCost
        });

        draftLine = new PurchaseBillLineFormModel();
        errorMessage = null;
    }

    private void RemoveLine(PurchaseBillLineFormModel line)
    {
        form.Lines.Remove(line);
    }

    private async Task SaveBillAsync(PurchaseBillSaveMode saveMode)
    {
        try
        {
            if (form.VendorId == Guid.Empty)
            {
                errorMessage = "Select a vendor first.";
                return;
            }

            if (form.Lines.Count == 0)
            {
                errorMessage = "Add at least one purchase bill line.";
                return;
            }

            if (form.Lines.Any(line => line.Quantity <= 0))
            {
                errorMessage = "Every purchase bill line must have quantity greater than zero.";
                return;
            }

            errorMessage = null;
            isSaving = true;
            form.BillDate = DateOnly.FromDateTime(billDate);
            form.DueDate = DateOnly.FromDateTime(dueDate);
            form.SaveMode = saveMode;

            await PurchaseBillsApi.CreateAsync(form);
            BackToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not save purchase bill. Details: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetItemName(Guid itemId)
    {
        return items.FirstOrDefault(item => item.Id == itemId)?.Name ?? itemId.ToString()[..8];
    }

    private void BackToList()
    {
        Navigation.NavigateTo("purchase-bills");
    }
}
