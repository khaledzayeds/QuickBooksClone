@page "/sales-orders/new"
@inject SalesOrdersApiClient SalesOrdersApi
@inject CustomersApiClient CustomersApi
@inject ItemsApiClient ItemsApi
@inject NavigationManager Navigation
@using QuickBooksClone.Maui.Services.Customers
@using QuickBooksClone.Maui.Services.Items
@using QuickBooksClone.Maui.Services.SalesOrders

<PageTitle>New Sales Order</PageTitle>

<div class="qb-page">
    <section class="qb-header">
        <div>
            <p class="eyebrow">Sales</p>
            <h1>New Sales Order</h1>
            <p class="muted">Capture the committed customer order now, then fulfill and invoice it in later steps.</p>
        </div>
        <button class="secondary-button" @onclick="BackToList">Back to Sales Orders</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <EditForm Model="form" class="panel form-panel page-form page-form-wide">
        <DataAnnotationsValidator />

        <label>
            Customer
            <InputSelect class="form-control" @bind-Value="form.CustomerId">
                <option value="@Guid.Empty">Select customer</option>
                @foreach (var customer in customers)
                {
                    <option value="@customer.Id">@customer.DisplayName</option>
                }
            </InputSelect>
        </label>

        <div class="form-row">
            <label>
                Order date
                <InputDate class="form-control" @bind-Value="orderDate" />
            </label>

            <label>
                Expected date
                <InputDate class="form-control" @bind-Value="expectedDate" />
            </label>
        </div>

        <h3>Lines</h3>
        <div class="form-row">
            <label>
                Item
                <InputSelect class="form-control" @bind-Value="draftLine.ItemId">
                    <option value="@Guid.Empty">Select item</option>
                    @foreach (var item in items)
                    {
                        <option value="@item.Id">@item.Name (@item.SalesPrice.ToString("N2"))</option>
                    }
                </InputSelect>
            </label>

            <label>
                Quantity
                <InputNumber class="form-control" @bind-Value="draftLine.Quantity" />
            </label>
        </div>

        <div class="form-row">
            <label>
                Unit price
                <InputNumber class="form-control" @bind-Value="draftLine.UnitPrice" />
            </label>

            <label>
                Description
                <InputText class="form-control" @bind-Value="draftLine.Description" />
            </label>
        </div>

        <button class="secondary-button" type="button" @onclick="AddLine">Add Line</button>

        @if (form.Lines.Count > 0)
        {
            <table class="data-table compact-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in form.Lines)
                    {
                        <tr>
                            <td>@GetItemName(line.ItemId)</td>
                            <td>@line.Quantity</td>
                            <td>@line.UnitPrice.ToString("N2")</td>
                            <td>@((line.Quantity * line.UnitPrice).ToString("N2"))</td>
                            <td><button class="link-button" type="button" @onclick="() => RemoveLine(line)">Remove</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="totals-box">
            Order total: @DraftTotal.ToString("N2")
            <small>Sales orders stay operational only until fulfillment and invoicing happen later.</small>
        </div>

        <div class="form-actions">
            <button class="primary-button" type="button" disabled="@isSaving" @onclick="() => SaveOrderAsync(SalesOrderSaveMode.SaveAsOpen)">
                @(isSaving ? "Saving..." : "Save as Open")
            </button>
            <button class="secondary-button" type="button" disabled="@isSaving" @onclick="() => SaveOrderAsync(SalesOrderSaveMode.Draft)">Save Draft</button>
            <button class="secondary-button" type="button" @onclick="BackToList">Cancel</button>
        </div>
    </EditForm>
</div>

@code {
    private List<CustomerDto> customers = [];
    private List<ItemDto> items = [];
    private SalesOrderFormModel form = new();
    private SalesOrderLineFormModel draftLine = new();
    private DateTime orderDate = DateTime.Today;
    private DateTime expectedDate = DateTime.Today.AddDays(7);
    private string? errorMessage;
    private bool isSaving;
    private decimal DraftTotal => form.Lines.Sum(line => line.Quantity * line.UnitPrice);

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupsAsync();
    }

    private async Task LoadLookupsAsync()
    {
        var customerResult = await CustomersApi.SearchAsync(null, false);
        customers = customerResult.Items.ToList();

        var itemResult = await ItemsApi.SearchAsync(null, false);
        items = itemResult.Items.ToList();
    }

    private void AddLine()
    {
        if (draftLine.ItemId == Guid.Empty || draftLine.Quantity <= 0)
        {
            errorMessage = "Select an item and enter a quantity greater than zero.";
            return;
        }

        var item = items.FirstOrDefault(current => current.Id == draftLine.ItemId);
        var unitPrice = draftLine.UnitPrice > 0 ? draftLine.UnitPrice : item?.SalesPrice ?? 0;

        form.Lines.Add(new SalesOrderLineFormModel
        {
            ItemId = draftLine.ItemId,
            Description = string.IsNullOrWhiteSpace(draftLine.Description) ? item?.Name : draftLine.Description,
            Quantity = draftLine.Quantity,
            UnitPrice = unitPrice
        });

        draftLine = new SalesOrderLineFormModel();
        errorMessage = null;
    }

    private void RemoveLine(SalesOrderLineFormModel line)
    {
        form.Lines.Remove(line);
    }

    private async Task SaveOrderAsync(SalesOrderSaveMode saveMode)
    {
        try
        {
            if (form.CustomerId == Guid.Empty)
            {
                errorMessage = "Select a customer first.";
                return;
            }

            if (form.Lines.Count == 0)
            {
                errorMessage = "Add at least one sales order line.";
                return;
            }

            if (expectedDate.Date < orderDate.Date)
            {
                errorMessage = "Expected date cannot be earlier than order date.";
                return;
            }

            errorMessage = null;
            isSaving = true;
            form.OrderDate = DateOnly.FromDateTime(orderDate);
            form.ExpectedDate = DateOnly.FromDateTime(expectedDate);
            form.SaveMode = saveMode;
            await SalesOrdersApi.CreateAsync(form);
            BackToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not save sales order. Details: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetItemName(Guid itemId) => items.FirstOrDefault(item => item.Id == itemId)?.Name ?? itemId.ToString()[..8];

    private void BackToList()
    {
        Navigation.NavigateTo("sales-orders");
    }
}
