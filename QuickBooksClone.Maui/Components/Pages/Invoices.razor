@page "/invoices"
@inject InvoicesApiClient InvoicesApi
@inject NavigationManager Navigation

<PageTitle>Invoices</PageTitle>

<div class="qb-page">
    <section class="qb-header">
        <div>
            <p class="eyebrow">Sales</p>
            <h1>Invoices</h1>
            <p class="muted">Create invoices, post them, then review their accounting effect in Transactions and Accounts.</p>
        </div>
        <button class="primary-button" @onclick="NewInvoice">New Invoice</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <section class="panel">
        <div class="toolbar">
            <input class="search-input" placeholder="Search invoice number" @bind="searchText" @bind:event="oninput" />
            <label class="check-row">
                <input type="checkbox" @bind="includeVoid" />
                Include void
            </label>
            <button class="secondary-button" @onclick="LoadInvoicesAsync" disabled="@isLoading">Search</button>
        </div>

        @if (isLoading)
        {
            <p class="muted">Loading invoices...</p>
        }
        else if (invoices.Count == 0)
        {
            <p class="muted">No invoices yet.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Number</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Due</th>
                        <th>Total</th>
                        <th>Balance</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in invoices)
                    {
                        <tr>
                            <td>
                                <strong>@invoice.InvoiceNumber</strong>
                                <small>@invoice.Id.ToString()[..8]</small>
                            </td>
                            <td>@invoice.CustomerName</td>
                            <td>@invoice.InvoiceDate</td>
                            <td>@invoice.DueDate</td>
                            <td>@invoice.TotalAmount.ToString("N2")</td>
                            <td>@invoice.BalanceDue.ToString("N2")</td>
                            <td><span class="status active">@invoice.Status</span></td>
                            <td class="actions">
                                <button class="link-button" @onclick="() => MarkSentAsync(invoice)">Mark sent</button>
                                <button class="link-button" @onclick="() => PostAsync(invoice)">Post</button>
                                <button class="link-button" @onclick="() => VoidAsync(invoice)">Void</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private List<InvoiceDto> invoices = [];
    private string? searchText;
    private string? errorMessage;
    private bool includeVoid;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadInvoicesAsync();
    }

    private async Task LoadInvoicesAsync()
    {
        try
        {
            errorMessage = null;
            isLoading = true;
            var result = await InvoicesApi.SearchAsync(searchText, includeVoid);
            invoices = result.Items.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load invoices. Make sure the API is running on http://localhost:5014. Details: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task MarkSentAsync(InvoiceDto invoice)
    {
        try
        {
            errorMessage = null;
            await InvoicesApi.MarkSentAsync(invoice.Id);
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not mark invoice as sent. Details: {ex.Message}";
        }
    }

    private async Task PostAsync(InvoiceDto invoice)
    {
        try
        {
            errorMessage = null;
            await InvoicesApi.PostAsync(invoice.Id);
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not post invoice. Details: {ex.Message}";
        }
    }

    private async Task VoidAsync(InvoiceDto invoice)
    {
        try
        {
            errorMessage = null;
            await InvoicesApi.VoidAsync(invoice.Id);
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not void invoice. Details: {ex.Message}";
        }
    }

    private void NewInvoice()
    {
        Navigation.NavigateTo("invoices/new");
    }
}
